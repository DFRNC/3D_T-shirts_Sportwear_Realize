{% liquid
  assign model_id = product.metafields.custom.id | default: ''
  assign variant = product.selected_or_first_available_variant
  assign variant_id = variant.id
  assign price = variant.price | divided_by: 100.0
  assign currency = shop.currency
%}

{% if model_id != '' %}
  <div
    id="r3f-root"
    class="r3f-configurator-container"
    data-model-id="{{ model_id }}"
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-variant-id="{{ variant_id }}"
    data-variant-title="{{ variant.title | escape }}"
    data-price="{{ price }}"
    data-currency="{{ currency }}"
    data-product-json="{{ product | json | escape }}"
    data-variant-json="{{ variant | json | escape }}"
  >
    <div class="r3f-loader">
      <p>Loading 3D Configurator...</p>
    </div>
  </div>

  <link rel="stylesheet" href="{{ 'r3f-configurator.css' | asset_url }}">

  <script type="module">
    import { initR3FConfigurator } from '{{ "r3f-configurator.js" | asset_url }}';
    const container = document.getElementById('r3f-root');
    if (container) {
      initR3FConfigurator(container).catch((error) => {
        console.error('R3F init error:', error);
        container.innerHTML = '<p class="r3f-error">Failed to load configurator.</p>';
      });
    }
  </script>

  <style>
    .r3f-configurator-container {
      width: 100%;
      min-height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #f5f5f5;
      border-radius: 8px;
      margin: 2rem 0;
    }
    .r3f-loader {
      text-align: center;
      padding: 2rem;
      color: #333;
      font-size: 16px;
    }
    .r3f-error {
      color: #dc2626;
      padding: 1rem;
      text-align: center;
      font-size: 14px;
    }
    .r3f-configurator-container > * {
      width: 100%;
      height: 100%;
    }
  </style>
{% endif %}
