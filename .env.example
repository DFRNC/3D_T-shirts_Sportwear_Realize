SHOPIFY_ENABLED=true
SHOPIFY_STORE_DOMAIN=realize2-0.myshopify.com

# Storefront API (production checkout + public catalog). Default when SHOPIFY_API_MODE is unset.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: admin API for local/dev when products are not published to Online Store.
# SHOPIFY_API_MODE=admin
# SHOPIFY_ADMIN_ACCESS_TOKEN=

SHOPIFY_API_VERSION=2025-01

# Comma-separated collection handles for home page order (defaults: calcio, pallavolo, basket, completo).
# SHOPIFY_HOME_COLLECTION_HANDLES=completo-gara-calcio,completo-gara-pallavolo,completo-gara-basket,completo

# Extra frame-ancestors origins for Shopify Theme Editor / custom domains (comma-separated).
SHOPIFY_FRAME_ANCESTORS=
