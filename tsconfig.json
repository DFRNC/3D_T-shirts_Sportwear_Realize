{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "baseUrl": ".",
    "types": ["@react-router/node", "vite/client", "@shopify/polaris-types"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@styles": ["./src/ui/styles/globals.css"],
      "@types": ["./src/types"],
      "@atoms": ["./src/ui/components/atomic/atoms"],
      "@molecules": ["./src/ui/components/atomic/molecules"],
      "@organisms": ["./src/ui/components/atomic/organisms"],
      "@templates": ["./src/ui/components/atomic/templates"],
      "@pages": ["./src/ui/components/atomic/pages"],
      "@shared": ["./src/ui/components/shared"],
      "@store": ["./src/store"],
      "@utils": ["./src/utils"],
      "@fonts": ["./src/fonts"],
      "@hooks": ["./src/hooks"],
      "@skeletons": ["./src/ui/components/skeletons"],
      "@gizmo": ["./src/gizmo"],
      "@providers": ["./src/providers"],
      "@shaders": ["./src/shaders"],
      "@constants": ["./src/constants"],
      "@data": ["./src/data"]
    }
  }
}
